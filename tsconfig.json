{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "declaration": false,
    "sourceMap": false,
    "noEmit": true,
    "rootDir": "src",
    "outDir": "src/dist"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/dist", "node_modules"]
}
